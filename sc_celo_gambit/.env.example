# ─── Deployer ────────────────────────────────────────────────────────────────
# Private key of the dedicated deployment wallet (NEVER use personal wallet)
PRIVATE_KEY=0x

# ─── Oracle ───────────────────────────────────────────────────────────────────
# Address of the oracle signer key managed by your KMS / server
ORACLE_ADDRESS=0x

# ─── Treasury ─────────────────────────────────────────────────────────────────
# Address that receives protocol fee share (can be a multisig)
TREASURY_ADDRESS=0x

# ─── Badge metadata ───────────────────────────────────────────────────────────
# Base URI for GambitBadges tokenURI (trailing slash required)
BADGE_BASE_URI=https://gambit.app/badges/

# ─── Verification ─────────────────────────────────────────────────────────────
# Get from https://celoscan.io/myapikey  (same key works for Alfajores/Sepolia)
CELOSCAN_API_KEY=
